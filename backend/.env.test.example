# Test Environment Variables
# Copy this file to .env.test and fill in your test database URL

# Test Database URL
# Use a separate test database to avoid affecting development/production data
# Example for PostgreSQL:
# TEST_DATABASE_URL="postgresql://user:password@localhost:5432/mynest_test?schema=public"
TEST_DATABASE_URL=""

# Optional: Firebase configuration for testing
# If you want to test Firebase authentication, provide test credentials
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# Optional: Skip authentication in tests (useful for unit tests)
# SKIP_AUTH="true"

# Optional: CORS origins for test environment
# ALLOW_ORIGINS="http://localhost:5173"
